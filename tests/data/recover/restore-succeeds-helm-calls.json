[
  [
    "repo",
    "add",
    "--force-update",
    "argoproj",
    "https://argoproj.github.io/argo-helm"
  ],
  [
    "repo",
    "add",
    "--force-update",
    "ricoberger",
    "https://ricoberger.github.io/helm-charts/"
  ],
  [
    "repo",
    "update"
  ],
  [
    "dependency",
    "update",
    "--skip-refresh"
  ],
  [
    "upgrade",
    "vault-secrets-operator",
    "<ANY>",
    "--install",
    "--values",
    "vault-secrets-operator/values.yaml",
    "--values",
    "vault-secrets-operator/values-idfdev.yaml",
    "--set",
    "vault-secrets-operator.vault.address=https://vault.lsst.cloud/",
    "--create-namespace",
    "--namespace",
    "vault-secrets-operator",
    "--timeout",
    "120s",
    "--wait"
  ],
  [
    "dependency",
    "update",
    "--skip-refresh"
  ],
  [
    "upgrade",
    "argocd",
    "<ANY>",
    "--install",
    "--values",
    "argocd/values.yaml",
    "--values",
    "argocd/values-idfdev.yaml",
    "--set",
    "global.vaultSecretsPath=secret/phalanx/idfdev",
    "--create-namespace",
    "--namespace",
    "argocd",
    "--timeout",
    "120s",
    "--wait"
  ]
]
